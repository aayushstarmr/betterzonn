from selenium import webdriver
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.common.by import By
import time

def search_amazon(query):
    options = Options()
    options.add_argument('--headless')
    options.add_argument('--no-sandbox')
    options.add_argument('--disable-gpu')
    driver = webdriver.Chrome(options=options)

    driver.get(f'https://www.amazon.in/s?k={query}')
    time.sleep(3)

    items = []
    products = driver.find_elements(By.CSS_SELECTOR, '[data-component-type="s-search-result"]')

    for product in products[:5]:
        try:
            name = product.find_element(By.TAG_NAME, 'h2').text
            link = product.find_element(By.TAG_NAME, 'a').get_attribute('href')
            price = product.find_element(By.CSS_SELECTOR, '.a-price-whole').text
            img = product.find_element(By.CSS_SELECTOR, 'img.s-image').get_attribute('src')

            items.append({
                'name': name,
                'price': f'₹{price}',
                'link': link,
                'image': img,
                'platform': 'Amazon'
            })
        except:
            continue

    driver.quit()
    return items
